exports[`time > renders time parser with addChecker max 1`] = `
"import * as DP from "@duplojs/utils/dataParser";

import * as D from "@duplojs/utils/date";

export const timeParserWithAddCheckerDataParser = DP.time({ checkers: [DP.checkerTimeMax(D.createTime(2, "millisecond"))] });"
`;

exports[`time > renders time parser with checker imports 1`] = `
"import * as DP from "@duplojs/utils/dataParser";

import * as D from "@duplojs/utils/date";

export const timeParserDataParser = DP.time({
    coerce: true,
    checkers: [DP.checkerTimeMin(D.createTime(1, "millisecond"))]
});"
`;

exports[`time > renders time parser with definition checkers 1`] = `
"import * as DP from "@duplojs/utils/dataParser";

import * as D from "@duplojs/utils/date";

export const timeParserWithDefinitionCheckersDataParser = DP.time({ checkers: [
        DP.checkerTimeMin(D.createTime(1, "millisecond")),
        DP.checkerTimeMax(D.createTime(2, "millisecond"))
    ] });"
`;

exports[`time > renders time parser without coerce and without checkers 1`] = `
"import * as DP from "@duplojs/utils/dataParser";

export const timeParserNoCoerceDataParser = DP.time();"
`;
