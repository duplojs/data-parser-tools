import * as SDP from "@duplojs/server-utils/dataParser";

export const fileParserDataParser = SDP.file({ coerce: true });"
`;

exports[`file > renders file parser with definition checkers 1`] = `
"import * as DP from "@duplojs/utils/dataParser";

import * as SDP from "@duplojs/server-utils/dataParser";

export const fileParserWithDefinitionCheckersDataParser = SDP.file({}, { checkers: [
        SDP.checkerFileExist(),
        SDP.checkerFileMimeType(/^image\\//)
    ] });"
`;

