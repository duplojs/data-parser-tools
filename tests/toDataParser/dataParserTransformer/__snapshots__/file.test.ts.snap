exports[`file > renders file parser with addChecker 1`] = `
"import * as DP from "@duplojs/utils/dataParser";

import * as SDP from "@duplojs/server-utils/dataParser";

export const fileParserWithAddCheckerDataParser = SDP.file({}, { checkers: [SDP.checkerFileSize({ min: 1, max: 10 })] });"
